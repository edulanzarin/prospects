# Copie este arquivo para ".env" e ajuste os valores antes de rodar
# "docker compose up -d --build".

# --- Banco de dados ---
POSTGRES_USER=navecon
POSTGRES_PASSWORD=changeme
POSTGRES_DB=navecon

# --- Autenticação ---
# Gere um valor aleatório com: openssl rand -base64 32
NEXTAUTH_SECRET=changeme
# URL/IP pelo qual o sistema será acessado, incluindo a porta 4013.
# Ex.: http://192.168.0.10:4013
NEXTAUTH_URL=http://localhost:4013

# --- Usuário administrador criado automaticamente no primeiro start ---
ADMIN_EMAIL=admin@navecon.com.br
ADMIN_PASSWORD=changeme
ADMIN_NOME=Administrador

# --- E-mail (opcional) ---
# Usado para o resumo diário de prospects em alerta. Se SMTP_HOST ficar
# em branco, o sistema funciona normalmente e apenas não envia e-mails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Navecon Prospecção <no-reply@navecon.com.br>
